<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ShapeableImageView 样式 -->
    <style name="RoundedCorner12">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="CircleShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- 自定义 CardView 样式 -->
    <style name="MyCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- 展开状态的标题样式 - 左边大标题 -->
    <style name="ExpandedAppBarTitle" parent="TextAppearance.AppCompat">
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:gravity">bottom|start</item>  <!-- 改为 start -->
    </style>

    <!-- 折叠状态的标题样式 - 左边小标题 -->
    <style name="CollapsedAppBarTitle" parent="TextAppearance.AppCompat">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:gravity">start|center_vertical</item>  <!-- 左边垂直居中 -->
        <item name="android:paddingStart">16dp</item>
    </style>
</resources>

